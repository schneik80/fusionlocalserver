# Copy to .env.local and fill in. .env.local is git-ignored.

# tldraw SDK licence key, from tldraw's sales team.
#
# Optional, but without it tldraw classifies any HTTPS page on a non-loopback
# hostname as an unlicensed production deployment and REPLACES THE WHITEBOARD
# WITH A HIDDEN DIV five seconds after it mounts — silently, with no console
# error. Since this app is served over HTTPS on a LAN hostname, that is the
# default outcome. See docs/whiteboards/STATUS.md.
#
# Vite inlines this into the whiteboard bundle at build time, so rebuild the web
# app after changing it.
VITE_TLDRAW_LICENSE_KEY=
