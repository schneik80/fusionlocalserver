probe-assembly

# Build secrets — store your client_id here, never commit it
.aps-client-id
.aps-region

# Build output
dist/
bin/

# Web UI build artifacts — the vite build writes hashed bundles into
# server/webdist/assets/ (embedded at compile time via go:embed), but the
# server/webdist/index.html placeholder IS committed so plain `go build`
# compiles before vite has ever run.
server/webdist/assets/
web/node_modules/
web/dist/
*.tsbuildinfo

# Go
*.test
*.out
vendor/

# Dependency cache
go/pkg/

# Auth & config (never commit credentials)
config/apsnav/
tokens.json
config.json
.env

# macOS
.DS_Store
.AppleDouble
.LSOverride

