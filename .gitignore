# Binary
fusionlocalserver
fusionlocalserver.exe
probe-assembly

# Build secrets — store your client_id here, never commit it
.aps-client-id
.aps-region
.aps-public-url

# Build output
dist/
bin/

# Web UI build artifacts — `vite build` writes the SPA into server/webdist/,
# which is embedded into the binary only by `go build -tags embed_ui` (see
# server/static_embed.go). The whole tree is pure build output: a plain
# `go build` uses the stub in server/static_stub.go and needs no files here.
server/webdist/
web/node_modules/
web/dist/
*.tsbuildinfo

# Go
*.test
*.out
vendor/

# Python (desktop/ manager apps)
__pycache__/
*.pyc

# Dependency cache
go/pkg/

# Auth & config (never commit credentials)
config/fusionlocalserver/
tokens.json
config.json
.env

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Editor
.idea/
.vscode/
*.swp
*.swo
*~
fusionlocalserver.zip

# Generated docs (e.g. README.pdf exports)
*.pdf

# Test coverage output
coverage.out
.claude/settings.local.json
